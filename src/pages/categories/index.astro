---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import BlogCategory from '@components/blog/BlogCategory.astro'
import MainSection from '@components/ui/sections/MainSection.astro'
import { timeago } from '@support/time'
import { SITE } from '@/config'

const postMap: Map<string, CollectionEntry<'posts'>[]> = (await getCollection('posts')).sort(
    (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).reduce((acc, obj) => {
    let posts = acc.get(obj.data.category)
    if (!posts) {
        posts = []
    }
    posts.push(obj)

    acc.set(obj.data.category, posts)

    return acc
}, new Map<string, CollectionEntry<'posts'>[]>())

const categoryDescriptions: Record<string, string> = {
    'ai': '围绕大模型接入、AI 工具链、智能化工作流，以及我在实际项目里踩过的坑',
    'backend': 'Java 语言体系、服务端架构设计、接口治理、稳定性建设、性能优化、工程规范和长期项目实践都会放在这里',
    'keyboard': '键盘配列、轴体、键帽和桌面输入体验相关折腾',
    'data-search': '数据库、搜索、向量检索、数据建模，以及数据处理链路里的实践记录',
    'framework': 'Spring、缓存、消息队列、中间件和开发框架的使用经验与问题复盘',
    'golang': 'Go 语言、编译原理、服务开发，以及一些偏底层的实验和学习记录',
    'homelab': '家用服务器、网络、NAS、虚拟化和个人基础设施的长期折腾现场',
    'infra': 'Linux、Docker、网络、部署、监控和自动化运维相关内容',
    'life': '生活、家庭、游戏和那些不完全属于技术但仍然值得记录的片段',
    'productivity': '效率工具、工作流、自动化脚本和让日常开发更顺手的方法',
    'share': '值得单独拿出来讲的经验、观点、事故复盘和高能分享',
    'tool': 'IDEA、VSCode、命令行、小插件，以及我日常使用或开发的工具',
    'tutorial': '偏教程向的内容，尽量把一个问题从背景到落地讲清楚',
    'zeka-stack': 'Zeka.Stack 是我长期打磨的一套工程化体系，包含项目脚手架、父 POM 分层、依赖治理、编码规范、基础组件、Maven 插件和自动化构建流程',
}

const categoryOrder = [
    'backend',
    'zeka-stack',
    'data-search',
    'ai',
    'golang',
    'framework',
    'homelab',
    'life',
    'infra',
    'productivity',
    'tool',
    'share',
    'tutorial',
    'keyboard',
]
const categoryPlacement: Record<string, string> = {
    'backend': 'lg:col-start-1 lg:row-start-1 lg:col-span-3 lg:row-span-2',
    'zeka-stack': 'lg:col-start-1 lg:row-start-3 lg:col-span-3 lg:row-span-2',
    'data-search': 'lg:col-start-4 lg:row-start-1 lg:col-span-1 lg:row-span-2',
    'ai': 'lg:col-start-5 lg:row-start-1 lg:col-span-1 lg:row-span-2',
    'golang': 'lg:col-start-6 lg:row-start-1 lg:col-span-1 lg:row-span-2',
    'framework': 'lg:col-start-4 lg:row-start-3 lg:col-span-3 lg:row-span-2',
    'homelab': 'lg:col-start-1 lg:row-start-5 lg:col-span-2 lg:row-span-2',
    'life': 'lg:col-start-3 lg:row-start-5 lg:col-span-1 lg:row-span-2',
    'infra': 'lg:col-start-4 lg:row-start-5 lg:col-span-2 lg:row-span-2',
    'productivity': 'lg:col-start-6 lg:row-start-5 lg:col-span-1 lg:row-span-2',
    'tool': 'lg:col-start-1 lg:row-start-7 lg:col-span-2 lg:row-span-2',
    'share': 'lg:col-start-3 lg:row-start-7 lg:col-span-2 lg:row-span-2',
    'tutorial': 'lg:col-start-5 lg:row-start-7 lg:col-span-1 lg:row-span-2',
    'keyboard': 'lg:col-start-6 lg:row-start-7 lg:col-span-1 lg:row-span-2',
}

const categoriesBySlug = new Map((await getCollection('categories')).map(category => [category.slug, category]))
const categories = categoryOrder
    .map(slug => categoriesBySlug.get(slug))
    .filter((category): category is CollectionEntry<'categories'> => Boolean(category))
const categoryCounts = categories.map(category => postMap.get(category.slug)?.length ?? 0)
const maxPostCount = Math.max(...categoryCounts, 1)
const categorySize: Record<string, 'sm' | 'md' | 'lg' | 'xl'> = {
    'backend': 'lg',
    'zeka-stack': 'lg',
}
const description = '这些分类基本覆盖了我长期写作的几个方向：后端工程、AI 工具、HomeLab、基础设施、效率工作流，以及一些值得单独记录的经验分享。分类大小会根据文章数量动态变化，越大的卡片代表我在这个方向投入得越多。'
const URL = Astro.url.href

function getCategorySize(count: number) {
    const ratio = count / maxPostCount
    if (ratio >= 0.75) {
        return 'xl'
    }

    if (ratio >= 0.45) {
        return 'lg'
    }

    if (ratio >= 0.2) {
        return 'md'
    }

    return 'sm'
}
---

<BaseLayout
    title="All Categories"
    description={description}
    structuredData={{
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        'inLanguage': 'en-US',
        '@id': URL,
        'url': URL,
        'name': `All Categories - ${SITE.title}`,
        'description': description,
        'isPartOf': {
            '@type': 'WebSite',
            'url': SITE.url,
            'name': SITE.title,
            'description': SITE.description,
        },
    }}

>
    <MainSection title="Categories" subTitle={description} />

    <section class="mx-auto px-4 py-10 sm:px-6 lg:px-8 lg:pt-10 lg:py-14 2xl:max-w-full">
        <div class="grid auto-rows-[88px] grid-cols-1 items-stretch gap-4 sm:grid-cols-2 lg:grid-cols-6 md:gap-5">
            {
                categories.map((c) => {
                    const count = postMap.get(c.slug)?.length ?? 0
                    return (
                        <BlogCategory
                            slug={c.slug}
                            title={c.data.title}
                            description={categoryDescriptions[c.slug] ?? c.data.description}
                            count={count}
                            size={categorySize[c.slug] ?? getCategorySize(count)}
                            placement={categoryPlacement[c.slug]}
                            publishDate={timeago(postMap.get(c.slug)?.[0]?.data?.pubDate)}
                        />
                    )
                })
            }
        </div>
    </section>
</BaseLayout>
