<script is:inline>
    const LIGHTBOX_ID = 'blog-image-lightbox'

    function ensureLightbox() {
        let root = document.getElementById(LIGHTBOX_ID)
        if (root) {
            return root
        }

        root = document.createElement('div')
        root.id = LIGHTBOX_ID
        root.className = 'blog-image-lightbox'
        root.setAttribute('aria-hidden', 'true')
        root.innerHTML = `
            <button class="blog-image-lightbox__close" type="button" aria-label="Close image preview">x</button>
            <img class="blog-image-lightbox__image" alt="" />
        `
        document.body.appendChild(root)

        const close = () => {
            root.classList.remove('is-open')
            root.setAttribute('aria-hidden', 'true')
            document.body.classList.remove('blog-image-lightbox-open')
        }

        root.addEventListener('click', (event) => {
            const target = event.target
            if (
                target === root
                || (target instanceof Element && target.closest('.blog-image-lightbox__close'))
            ) {
                close()
            }
        })

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && root.classList.contains('is-open')) {
                close()
            }
        })

        root.openImage = (src, alt) => {
            const image = root.querySelector('.blog-image-lightbox__image')
            image.src = src
            image.alt = alt || ''
            root.classList.add('is-open')
            root.setAttribute('aria-hidden', 'false')
            document.body.classList.add('blog-image-lightbox-open')
        }

        return root
    }

    function bindBlogImages() {
        const images = document.querySelectorAll('article.prose img:not([data-lightbox-bound])')
        images.forEach((image) => {
            image.dataset.lightboxBound = 'true'
            image.classList.add('blog-image-lightbox-trigger')
            image.addEventListener('click', () => {
                const root = ensureLightbox()
                root.openImage(image.currentSrc || image.src, image.alt)
            })
        })
    }

    document.addEventListener('DOMContentLoaded', bindBlogImages)
    document.addEventListener('astro:page-load', bindBlogImages)
</script>

<style is:global>
    .blog-image-lightbox-trigger {
        border-radius: 6px;
        box-shadow: 0 8px 24px rgb(15 23 42 / 12%);
        cursor: zoom-in;
    }

    .blog-image-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgb(0 0 0 / 82%);
    }

    .blog-image-lightbox.is-open {
        display: flex;
    }

    .blog-image-lightbox__image {
        max-width: min(92vw, 1400px);
        max-height: 90vh;
        object-fit: contain;
        border-radius: 6px;
        box-shadow: 0 24px 80px rgb(0 0 0 / 45%);
        cursor: zoom-out;
    }

    .blog-image-lightbox__close {
        position: fixed;
        top: 16px;
        right: 16px;
        width: 40px;
        height: 40px;
        border: 0;
        border-radius: 999px;
        background: rgb(255 255 255 / 14%);
        color: white;
        font-size: 24px;
        line-height: 1;
        cursor: pointer;
    }

    .blog-image-lightbox__close:hover {
        background: rgb(255 255 255 / 24%);
    }

    body.blog-image-lightbox-open {
        overflow: hidden;
    }
</style>
