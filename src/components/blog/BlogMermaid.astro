<script>
import mermaid from 'mermaid'

const MERMAID_SELECTOR = 'article.prose .mermaid'
const MERMAID_PENDING_SELECTOR = `${MERMAID_SELECTOR}:not([data-processed]):not([data-mermaid-state="rendered"])`
let renderQueue = Promise.resolve()

function resolveTheme() {
    return document.documentElement.classList.contains('dark') ? 'dark' : 'default'
}

function initializeMermaid() {
    mermaid.initialize({
        startOnLoad: false,
        securityLevel: 'strict',
        theme: resolveTheme(),
    })
}

async function renderDiagram(diagram: HTMLElement) {
    if (diagram.dataset.mermaidState === 'rendering' || diagram.dataset.mermaidState === 'rendered') {
        return
    }

    diagram.dataset.mermaidState = 'rendering'
    await mermaid.run({
        nodes: [diagram],
    })
    diagram.dataset.mermaidState = 'rendered'
}

function queueRender(diagram: HTMLElement) {
    renderQueue = renderQueue
        .then(() => renderDiagram(diagram))
        .catch((error) => {
            diagram.dataset.mermaidState = 'error'
            console.error('Failed to render Mermaid diagram:', error)
        })
}

function observeMermaid(diagrams: HTMLElement[]) {
    if (!('IntersectionObserver' in window)) {
        diagrams.forEach(queueRender)
        return
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (!entry.isIntersecting) {
                return
            }

            const diagram = entry.target as HTMLElement
            observer.unobserve(diagram)
            queueRender(diagram)
        })
    }, {
        rootMargin: '600px 0px',
        threshold: 0.01,
    })

    diagrams.forEach(diagram => observer.observe(diagram))
}

function setupMermaid() {
    const diagrams = Array.from(document.querySelectorAll<HTMLElement>(MERMAID_PENDING_SELECTOR))
    if (diagrams.length === 0) {
        return
    }

    initializeMermaid()
    diagrams.forEach((diagram) => {
        diagram.dataset.mermaidState = 'pending'
    })
    observeMermaid(diagrams)
}

document.addEventListener('DOMContentLoaded', () => {
    setupMermaid()
})
</script>

